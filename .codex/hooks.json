{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/pre-edit-branch-guard.sh",
            "timeout": 5,
            "statusMessage": "Checking branch..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/pre-commit-gate.sh",
            "timeout": 30,
            "statusMessage": "Running type-check before commit..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/post-edit-format.sh",
            "timeout": 15,
            "statusMessage": "Formatting..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.codex/hooks/post-commit-doc-reminder.sh",
            "timeout": 10,
            "statusMessage": "Checking if docs need updating..."
          }
        ]
      }
    ]
  }
}
