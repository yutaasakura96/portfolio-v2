{
  "mcpServers": {
    "portfolio": {
      "type": "stdio",
      "command": "npx",
      "args": ["tsx", "--env-file=.env", "mcp/portfolio-server/src/index.ts"]
    },
    "portfolio-prod": {
      "type": "stdio",
      "command": "npx",
      "args": ["tsx", "--env-file=.env", "mcp/portfolio-server/src/index.ts"],
      "env": {
        "PORTFOLIO_BASE_URL": "https://asakurayuta.dev"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--headless"],
      "env": {}
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      }
    }
  }
}
