# ─────────────────────────────────────────────────────────────────────────────
# Local environment template. Copy to `.env` and fill in real values.
# Canonical variable list + production source of truth lives in:
#   .claude/docs/infrastructure.md  §Environment Variables
# Note: AWS Amplify reserves the `AWS_*` namespace, so app-side AWS credentials
# use the `APP_AWS_*` prefix (matched by src/lib/aws/* and amplify.yml).
# ─────────────────────────────────────────────────────────────────────────────

# ═══ Database (Neon) ═══
# CONNECTION POOLING URL (use for application queries)
DATABASE_URL="postgresql://user:pass@ep-xyz-123-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
# DIRECT URL without pooling (use for migrations)
DIRECT_URL="postgresql://user:pass@ep-xyz-123.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ═══ AWS General ═══
APP_AWS_REGION="ap-southeast-1"
APP_AWS_ACCESS_KEY_ID="your-access-key"
APP_AWS_SECRET_ACCESS_KEY="your-secret-key"

# ═══ AWS Cognito ═══
COGNITO_USER_POOL_ID="ap-southeast-1_xxxxxxxx"
COGNITO_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxx"
COGNITO_CLIENT_SECRET="your-client-secret"
COGNITO_DOMAIN="your-domain.auth.ap-southeast-1.amazoncognito.com"

# ═══ AWS S3 ═══
S3_BUCKET_NAME="portfolio-images-bucket"
S3_REGION="ap-southeast-1"

# ═══ AWS CloudFront ═══
CLOUDFRONT_DISTRIBUTION_ID="EXXXXXXXXXX"
CLOUDFRONT_DOMAIN="dxxxxxxxxxx.cloudfront.net"

# ═══ AWS SES ═══
SES_FROM_EMAIL="noreply@yourdomain.com"
CONTACT_EMAIL="your@email.com"

# ═══ Upstash Redis (rate limiting) ═══
# Used by src/lib/rate-limit.ts for the contact + upload endpoints.
# Provision a Redis DB at https://console.upstash.com — see .claude/docs/infrastructure.md.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ═══ App ═══
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CLOUDFRONT_URL="https://dxxxxxxxxxx.cloudfront.net"

# ═══ Neon Branch Management ═══
# Used by scripts/neon-reset-dev.sh to restore dev branch from prod.
# API key: https://console.neon.tech/app/settings/api-keys
# Project/branch IDs: visible in Neon console URLs.
NEON_API_KEY=""
NEON_PROJECT_ID=""
NEON_PROD_BRANCH_ID=""
NEON_DEV_BRANCH_ID=""
