# ─────────────────────────────────────────────────────────────────────────────
# Local environment template. Copy to `.env` and fill in real values.
# Canonical variable list + production source of truth lives in:
#   .claude/docs/infrastructure.md  §Environment Variables
# Note: AWS Amplify reserves the `AWS_*` namespace, so app-side AWS credentials
# use the `APP_AWS_*` prefix (matched by src/lib/aws/* and amplify.yml).
# ─────────────────────────────────────────────────────────────────────────────

# ═══ Database (Neon) ═══
# CONNECTION POOLING URL (use for application queries)
DATABASE_URL="postgresql://user:pass@ep-xyz-123-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
# DIRECT URL without pooling (use for migrations)
DIRECT_URL="postgresql://user:pass@ep-xyz-123.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ═══ AWS General ═══
APP_AWS_REGION="ap-southeast-1"
APP_AWS_ACCESS_KEY_ID="your-access-key"
APP_AWS_SECRET_ACCESS_KEY="your-secret-key"

# ═══ AWS Cognito (server-side) ═══
COGNITO_USER_POOL_ID="ap-southeast-1_xxxxxxxx"
COGNITO_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxx"
COGNITO_CLIENT_SECRET="your-client-secret"
COGNITO_REGION="ap-southeast-1"
COGNITO_DOMAIN="your-domain.auth.ap-southeast-1.amazoncognito.com"

# Cognito Hosted UI callback/redirect/signout URLs — local + prod variants.
# Must match the allowed URLs configured in the Cognito app client.
COGNITO_ALLOWED_CALLBACK_URL_LOCAL="http://localhost:3000/api/auth/callback"
COGNITO_ALLOWED_SIGNOUT_URL_LOCAL="http://localhost:3000"
COGNITO_ALLOWED_CALLBACK_URL_PROD="https://yourdomain.com/api/auth/callback"
COGNITO_DEFAULT_REDIRECT_URL="https://yourdomain.com/api/auth/callback"
COGNITO_ALLOWED_SIGNOUT_URL_PROD="https://yourdomain.com"

# Optional: full Hosted UI login URLs for manual testing (not used by app code)
# COGNITO_LOGIN_URL_LOCAL="https://your-domain.auth.ap-southeast-1.amazoncognito.com/login?client_id=xxxxxxxxxxxxxxxxxxxxxxxxxx&response_type=code&scope=email+openid+profile&redirect_uri=http%3A%2F%2Flocalhost%3A3000%2Fapi%2Fauth%2Fcallback"
# COGNITO_LOGIN_URL_PROD="https://your-domain.auth.ap-southeast-1.amazoncognito.com/login?client_id=xxxxxxxxxxxxxxxxxxxxxxxxxx&response_type=code&scope=email+openid+profile&redirect_uri=https%3A%2F%2Fyourdomain.com%2Fapi%2Fauth%2Fcallback"

# ═══ AWS S3 ═══
S3_BUCKET_NAME="portfolio-images-bucket"
S3_REGION="ap-southeast-1"

# ═══ AWS CloudFront ═══
CLOUDFRONT_DISTRIBUTION_ID="EXXXXXXXXXX"
CLOUDFRONT_DOMAIN="dxxxxxxxxxx.cloudfront.net"

# ═══ AWS SES ═══
SES_FROM_EMAIL="noreply@yourdomain.com"
CONTACT_EMAIL="your@email.com"

# ═══ Upstash Redis (rate limiting) ═══
# Used by src/lib/rate-limit.ts for the contact, upload, import, and export endpoints.
# Provision a Redis DB at https://console.upstash.com — see .claude/docs/infrastructure.md.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ═══ App ═══
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CLOUDFRONT_URL="https://dxxxxxxxxxx.cloudfront.net"

# Client-side Cognito config (embedded in the frontend bundle — no secrets here).
# Used by useAuth() and browser-side Hosted UI redirects.
NEXT_PUBLIC_COGNITO_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_COGNITO_DOMAIN="your-domain.auth.ap-southeast-1.amazoncognito.com"

# ═══ Sentry (error tracking) ═══
# DSN is public (embedded in the bundle). Auth token is build-time only — used for source-map uploads.
NEXT_PUBLIC_SENTRY_DSN="https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXXXXXXXXXXXX.ingest.us.sentry.io/XXXXXXXXXXXXXXX"
SENTRY_AUTH_TOKEN=""

# ═══ Portfolio MCP ═══
# API key for the local Portfolio MCP server (mcp/portfolio-server) — used for
# requireAuthOrApiKey-gated CMS routes when driving content from MCP tools.
PORTFOLIO_API_KEY=""

# ═══ Neon Branch Management ═══
# Used by scripts/neon-reset-dev.sh to restore dev branch from prod.
# API key: https://console.neon.tech/app/settings/api-keys
# Project/branch IDs: visible in Neon console URLs.
NEON_API_KEY=""
NEON_PROJECT_ID=""
NEON_PROD_BRANCH_ID=""
NEON_DEV_BRANCH_ID=""

# ═══ Anthropic (certificate extraction) ═══
# Used by /api/admin/certifications/extract to auto-fill form fields from certificate images.
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# ═══ Deployment / Test Helpers (optional) ═══
# AMPLIFY_DOMAIN — Amplify branch URL, useful when testing against a deployed branch.
# TEST_EMAIL / TEST_PASSWORD — credentials for manual auth-flow testing only.
# AMPLIFY_DOMAIN="https://main.xxxxxxxxxxxxxx.amplifyapp.com"
# TEST_EMAIL="your@email.com"
# TEST_PASSWORD="your-test-password"
